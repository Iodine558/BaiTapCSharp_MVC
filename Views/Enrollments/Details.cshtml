@model BaiTapCSharp_MVC.Models.Enrollment

@{
	ViewData["Title"] = "Enrollment Details";
}

<h1>Enrollment Details</h1>

<div>
	<hr />
	<dl class="row">
		<dt class="col-sm-2">Student</dt>
		<dd class="col-sm-10">@Model.Student?.Name</dd>
		<dt class="col-sm-2">Class Section</dt>
		<dd class="col-sm-10">@Model.ClassSection?.Name</dd>
	</dl>
</div>
<div>
	<a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
	<a asp-action="Index">Back to List</a>
</div>
